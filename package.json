{
  "name": "codexa-host",
  "version": "1.0.0",
  "description": "Codexa Lecturer Desktop Application Host",
  "author": "Codexa Team <info@codexa.com>",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "package:linux": "electron-builder --linux",
    "package:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "asar": false,
    "appId": "com.codexa.host",
    "productName": "CodexaHost",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "backend/dist/**/*",
      "backend/prisma/**/*",
      "backend/package.json",
      "frontend/.next/**/*",
      "frontend/public/**/*",
      "frontend/package.json",
      "electron-main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/node_modules",
        "to": "app/backend/node_modules"
      },
      {
        "from": "frontend/node_modules",
        "to": "app/frontend/node_modules"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    }
  }
}
